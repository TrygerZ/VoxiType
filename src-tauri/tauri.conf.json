{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxiType",
  "version": "0.4.2",
  "identifier": "com.voxitype.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxiType",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true
      },
      {
        "label": "floating-widget",
        "url": "floating.html",
        "title": "VoxiType Widget",
        "width": 180,
        "height": 88,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11434 https://api.groq.com; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsh", "uninstallerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

